<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.IProductDao">

    <resultMap id="ProductResultMap" type="org.example.domain.po.Product">
        <id column="id" property="id"/>
        <result column="product_name" property="productName"/>
        <result column="price" property="price"/>
        <result column="stock" property="stock"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryById" parameterType="java.lang.Long" resultMap="ProductResultMap">
        SELECT * FROM product WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="ProductResultMap">
        SELECT * FROM product ORDER BY id DESC
    </select>

    <insert id="insert" parameterType="org.example.domain.po.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (product_name, price, stock, description)
        VALUES (#{productName}, #{price}, #{stock}, #{description})
    </insert>

    <update id="updateById" parameterType="org.example.domain.po.Product">
        UPDATE product
        <set>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM product WHERE id = #{id}
    </delete>

    <update id="deductStock">
        UPDATE product SET stock = stock - #{quantity}
        WHERE id = #{productId} AND stock >= #{quantity}
    </update>

</mapper>